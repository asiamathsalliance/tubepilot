# Copy to youtube.env (do not commit) and fill in from Google Cloud Console.
# OAuth client: Web application; Authorized redirect URI:
#   http://127.0.0.1:34567/oauth2callback
#
# Scopes (if you did not see “Add or remove scopes” during setup):
#   Google Cloud → APIs & Services → OAuth consent screen → Edit app
#   → Data access (or “Scopes”) → Add or remove scopes
#   → filter “YouTube” → enable at least:
#     .../auth/youtube.upload  and  .../auth/youtube
#   Save. If the app is in “Testing”, add your Google account under Test users.
#
# After copying to youtube.env, paste real values on the lines below.
# Refresh tokens often start with 1// — use double quotes or Node --env-file treats // as a comment:
#   YOUTUBE_REFRESH_TOKEN="1//...."
# If npm says credentials are missing but you see them in the editor, save the file.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# From: npm run youtube:token  (after one-time browser consent)
YOUTUBE_REFRESH_TOKEN=

# Optional: override port for the local OAuth callback
# YOUTUBE_OAUTH_PORT=34567
